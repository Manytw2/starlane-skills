.         // Validate: heterogeneity_discrete must be variable names (e.g. SOE|
> Region), not parameter names
.         foreach _v of global heterogeneity_discrete {
  2.                 if regexm(`"`_v'"', "^_") | regexm(`"`_v'"', "_arg$") {
