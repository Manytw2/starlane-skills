> ' - 1)
  9.                         local rob_rest = substr("`rob_rest'", `pipe_pos' +
>  1, .)
 10.                 }
 11.                 local colon_pos = strpos("`rob_item'", ":")
 12.                 if `colon_pos' > 0 {
 13.                         local rob_type = substr("`rob_item'", 1, `colon_po
> s' - 1)
 14.                         local rob_value = substr("`rob_item'", `colon_pos'
>  + 1, .)
 15.                         if "`rob_type'" == "ln_y" global rob_ln_y "`rob_va
> lue'"
 16.                         if "`rob_type'" == "alt_x" global rob_alt_x "`rob_
> value'"
 17.                         if "`rob_type'" == "ln_x" global rob_ln_x "`rob_va
> lue'"
 18.                         if "`rob_type'" == "alt_y" global rob_alt_y "`rob_
> value'"
 19.                         if "`rob_type'" == "lag" global rob_lag_periods "`
> rob_value'"
 20.                 }
 21.         }
. }

