. // Build cv_optional = cv_all - cv_fixed
. local cv_optional ""

. foreach v of global cv_all {
  2.         local in_fixed 0
  3.         foreach f of global cv_fixed {
  4.                 if "`v'" == "`f'" {
  5.                         local in_fixed 1
  6.                         continue
  7.                 }
  8.         }
  9.         if !`in_fixed' {
 10.                 local cv_optional "`cv_optional' `v'"
 11.         }
 12. }

. global cv_optional `cv_optional'

. 
. local n_fixed : word count $cv_fixed

. local n_opt : word count $cv_optional

. local min_extra = max(0, `cv_min_count' - `n_fixed')

. 
. // Generate valid cv subsets in memory (no file I/O; use locals for fast acce
> ss)
. local n_valid 0

. local max_i = 2^`n_opt' - 1

. if `n_opt' == 0 {
.         local max_i 0
. }

. forvalues i = 0/`max_i' {
  2.         local c 0
  3.         if `n_opt' > 0 {
  4.                 forvalues j = 1/`n_opt' {
  5.                         local pow = 2^(`j'-1)
  6.                         if mod(int(`i'/`pow'), 2) {
  7.                                 local c = `c' + 1
  8.                         }
  9.                 }
 10.         }
 11.         if `c' >= `min_extra' {
 12.                 local subs "$cv_fixed"
 13.                 if `n_opt' > 0 {
 14.                         forvalues j = 1/`n_opt' {
 15.                                 local pow = 2^(`j'-1)
 16.                                 if mod(int(`i'/`pow'), 2) {
 17.                                         local w "`=word("$cv_optional", `j
> ')'"
 18.                                         local subs "`subs' `w'"
 19.                                 }
 20.                         }
 21.                 }
 22.                 local cv_sub_`n_valid' "`subs'"
 23.                 local n_valid = `n_valid' + 1
 24.         }
 25. }

. 
. if `n_valid' == 0 {
.         di as error "No valid cv subsets. Check cv_fixed and cv_min_count."
.         exit 198
. }

