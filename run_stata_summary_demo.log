. capture program drop _calc_effective_stars

. program define _calc_effective_stars
  1.         args coef se
  2.         local effective_stars 0
  3.         if !missing(`coef') & !missing(`se') & `se' > 0 {
  4.                 local dir_ok 0
  5.                 if ("$coef_direction" == "positive" & `coef' > 0) | ("$coe
> f_direction" == "negative" & `coef' < 0) {
  6.                         local dir_ok 1
  7.                 }
  8.                 if `dir_ok' {
  9.                         capture local df = e(df_r)
 10.                         if _rc != 0 | missing(`df') {
 11.                                 capture local df = e(N) - e(df_m) - 1
 12.                         }
 13.                         if missing(`df') | `df' <= 0 {
 14.                                 local df 999999
 15.                         }
 16.                         local t = `coef' / `se'
 17.                         local pval = 2 * ttail(`df', abs(`t'))
 18.                         local effective_stars = cond(`pval' < 0.01, 3, con
> d(`pval' < 0.05, 2, cond(`pval' < 0.1, 1, 0)))
 19.                 }
 20.         }
 21.         c_local effective_stars `effective_stars'
 22. end

. 
. capture program drop _post_coef

. program define _post_coef
  1.         args scorehandle vce_suffix section target_var
  2.         local coef = _b[`target_var']
  3.         local se   = _se[`target_var']
  4.         local dep  = "`e(depvar)'"
  5.         _calc_effective_stars `coef' `se'
  6.         post `scorehandle' ("`vce_suffix'") ("`section'") ("`dep'") ("`tar
> get_var'") (`coef') (`se') (`effective_stars')
  7. end

