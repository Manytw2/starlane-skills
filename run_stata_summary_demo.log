. // Outer loop: cv subsets (full or chunk range)
. // Avoid cond() with empty cv_start/cv_end when use_range=0
. local loop_start 0

. local loop_end = `n_valid' - 1

. if `use_range' {
.         local loop_start `cv_start'
.         local loop_end `cv_end'
. }

. forvalues cv_idx = `loop_start'/`loop_end' {
  2.         local cv_subset "`cv_sub_`cv_idx''"
  3.         global cv "`cv_subset'"
  4. 
.         // Sample size check: skip cv_subset if insufficient observations for
>  y,x,cv,panel,time
.         preserve
  5.         quietly egen _n_check = rowmiss($y $x $cv $panelvar $timevar)
  6.         quietly keep if _n_check == 0
  7.         local n_avail = _N
  8.         restore
  9.         if `n_avail' < `min_n_cv' {
 10.                 continue
 11.         }
 12. 
.         // Sample pool and __base_sample per cv_subset (align with final-stag
> e output)
.         local sample_pool_vars "$panelvar $timevar $y $x $cv"
 13.         if "$meds" != "" local sample_pool_vars "`sample_pool_vars' $meds"
 14.         if "$mods" != "" local sample_pool_vars "`sample_pool_vars' $mods"
 15.         if "$iv" != "" local sample_pool_vars "`sample_pool_vars' $iv"
 16.         if "$heterogeneity_discrete" != "" local sample_pool_vars "`sample
> _pool_vars' $heterogeneity_discrete"
 17.         if "$rob_alt_x" != "" local sample_pool_vars "`sample_pool_vars' $
> rob_alt_x"
 18.         if "$rob_alt_y" != "" local sample_pool_vars "`sample_pool_vars' $
> rob_alt_y"
 19.         quietly egen __base_miss = rmiss(`sample_pool_vars')
 20.         quietly gen byte __base_raw_ok = (__base_miss == 0)
 21.         quietly drop __base_miss
 22.         local first_y : word 1 of $y
 23.         local first_x : word 1 of $x
 24.         capture quietly reghdfe `first_y' `first_x' $cv if __base_raw_ok, 
> absorb($timevar $panelvar)
 25.         if _rc != 0 {
 26.                 quietly drop __base_raw_ok
 27.                 continue
 28.         }
 29.         quietly gen byte __base_sample = e(sample)
