. capture program drop _urldecode

. program define _urldecode
  1.         args raw_input
  2.         local in `"`raw_input'"'
  3.         local out ""
  4.         local in_len = length(`"`in'"')
  5.         local i 1
  6.         while `i' <= `in_len' {
  7.                 local ch = substr(`"`in'"', `i', 1)
  8.                 if "`ch'" == "%" & `i' + 2 <= `in_len' {
  9.                         local hexpair = upper(substr(`"`in'"', `i' + 1, 2)
> )
 10.                         local h1 = strpos("0123456789ABCDEF", substr("`hex
> pair'", 1, 1))
 11.                         local h2 = strpos("0123456789ABCDEF", substr("`hex
> pair'", 2, 1))
 12.                         if `h1' > 0 & `h2' > 0 {
 13.                                 local ascii = (`h1' - 1) * 16 + (`h2' - 1)
 14.                                 local out = `"`out'"' + char(`ascii')
 15.                                 local i = `i' + 3
 16.                                 continue
 17.                         }
 18.                 }
 19.                 local out = `"`out'"' + "`ch'"
 20.                 local i = `i' + 1
 21.         }
 22.         c_local decoded `"`out'"'
 23. end

. 
. capture program drop _load_discrete_values_for_var

. program define _load_discrete_values_for_var
  1.         args raw target_var prefix
  2.         local count 0
  3.         c_local `prefix'_count 0
  4.         local rest `"`raw'"'
  5.         while `"`rest'"' != "" {
  6.                 local pipe_pos = strpos(`"`rest'"', "|")
  7.                 if `pipe_pos' == 0 {
  8.                         local item `"`rest'"'
  9.                         local rest ""
 10.                 }
 11.                 else {
 12.                         local item = substr(`"`rest'"', 1, `pipe_pos' - 1)
 13.                         local rest = substr(`"`rest'"', `pipe_pos' + 1, .)
 14.                 }
 15.                 local colon_pos = strpos(`"`item'"', ":")
 16.                 if `colon_pos' <= 0 {
 17.                         continue
 18.                 }
 19.                 local key_encoded = trim(substr(`"`item'"', 1, `colon_pos'
>  - 1))
 20.                 local values_encoded = trim(substr(`"`item'"', `colon_pos'
>  + 1, .))
 21.                 _urldecode `"`key_encoded'"'
 22.                 local parsed_key `"`decoded'"'
 23.                 if `"`parsed_key'"' != `"`target_var'"' {
 24.                         continue
 25.                 }
 26.                 local values_rest `"`values_encoded'"'
 27.                 while `"`values_rest'"' != "" {
 28.                         local sep_pos = strpos(`"`values_rest'"', ";")
 29.                         if `sep_pos' == 0 {
 30.                                 local value_encoded `"`values_rest'"'
 31.                                 local values_rest ""
 32.                         }
 33.                         else {
 34.                                 local value_encoded = substr(`"`values_res
> t'"', 1, `sep_pos' - 1)
 35.                                 local values_rest = substr(`"`values_rest'
> "', `sep_pos' + 1, .)
 36.                         }
 37.                         local value_encoded = trim(`"`value_encoded'"')
 38.                         if `"`value_encoded'"' == "" {
 39.                                 continue
 40.                         }
 41.                         _urldecode `"`value_encoded'"'
 42.                         local value_decoded `"`decoded'"'
 43.                         if `"`value_decoded'"' == "" {
 44.                                 continue
 45.                         }
 46.                         local count = `count' + 1
 47.                         c_local `prefix'_enc_`count' `"`value_encoded'"'
 48.                         c_local `prefix'_dec_`count' `"`value_decoded'"'
 49.                         c_local `prefix'_count `count'
 50.                 }
 51.                 continue, break
 52.         }
 53. end

