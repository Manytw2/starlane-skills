315.                         }
316.                 }
317.                 local n_pad = `n_coef' - `n_rows'
318.                 forvalues i = 1/`=max(0, `n_pad')' {
319.                         local row_vals "`row_vals',"
320.                 }
321.                 if length("`row_vals'") > 0 {
322.                         local row_vals = substr("`row_vals'", 1, length("`
> row_vals'") - 1)
323.                 }
324.                 restore
325. 
.                 local score_str = strofreal(scalar(`S_score'))
326.                 local cv_selected_csv = subinstr("`cv_subset'", " ", "|", 
> .)
327.                 file write `csv_fh' "`selection_id',`cv_idx',`vce_idx0',`v
> ce_suffix',`cv_selected_csv',`score_str',`row_vals'" _n
328. 
.                 * Temp files; cleanup runs periodically.
.         }
329.         quietly drop __base_sample
330. }
